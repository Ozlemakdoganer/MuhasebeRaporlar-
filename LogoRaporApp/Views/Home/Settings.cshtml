@{
    Layout = null;
}
@if (ViewBag.NeedFirmSelection == true)
{
    <div class="alert alert-warning mb-4">
        Firma / dönem seçimi henüz yapılmamış. Raporları kullanabilmek için seçim yapmanız gerekiyor.
    </div>
}



<div>
    <h4 class="mb-3">Ayarlar</h4>

    <p class="text-muted mb-4">
        Buradan sistem ayarlarını yönetebilirsiniz.
    </p>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100" style="cursor:pointer;" onclick="veritabaniAyarlariGetir()">
                <div class="card-body">
                    <h5 class="card-title">Veritabanı Ayarları</h5>
                    <p class="card-text text-muted">
                        SQL bağlantı bilgilerini buradan tanımlayın.                       
                    </p>
                    @if (ViewBag.DbConnected == true)
                    {
                        <div class="text-success small fw-semibold">Durum: Bağlı</div>
                    }
                    else
                    {
                        <div class="text-danger small fw-semibold">Durum: Bağlı değil</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100" style="cursor:pointer;" onclick="firmaSecimGetir()">
                <div class="card-body">
                    <h5 class="card-title">Firma / Dönem Ayarları</h5>
                    <p class="card-text text-muted">
                        Firma ve dönem seçimini buradan güncelleyebilirsiniz.                        
                    </p>
                    @if (ViewBag.SelectedFirm != null && ViewBag.SelectedPeriod != null)
                    {
                        <div class="text-success small fw-semibold">
                            Durum: @ViewBag.SelectedFirm / @ViewBag.SelectedPeriod seçili
                        </div>
                    }
                    else
                    {
                        <div class="text-danger small fw-semibold">
                            Durum: Henüz seçilmedi
                        </div>
                    }
                </div>
            </div>
        </div>


        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100 opacity-50">
                <div class="card-body">
                    <h5 class="card-title">Rapor Ayarları</h5>
                    <p class="card-text text-muted">
                        Yakında eklenecek.
                    </p>
                </div>
            </div>
        </div>

        @if (Context.Session.GetString("role") == "Admin")
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100" style="cursor:pointer;" onclick="kullaniciYonetimiGetir()">
                    <div class="card-body">
                        <h5 class="card-title">Kullanıcı Yönetimi</h5>
                        <p class="card-text text-muted">
                            Kullanıcı ekle, sil veya şifre değiştir.
                        </p>
                        <div class="text-success small fw-semibold">Sadece Admin</div>
                    </div>
                </div>
            </div>
        }

        @if (Context.Session.GetString("role") == "Admin")
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100" style="cursor:pointer;" onclick="rolYonetimiGetir()">
                    <div class="card-body">
                        <h5 class="card-title">Rol Yönetimi</h5>
                        <p class="card-text text-muted">
                            Rol ekle, sil ve rapor izinlerini yönet.
                        </p>
                        <div class="text-success small fw-semibold">Sadece Admin</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
