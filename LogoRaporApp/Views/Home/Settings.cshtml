@model LogoRaporApp.Models.DbSetting

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Veritabanı Bağlantısı</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background: linear-gradient(135deg, #0f172a, #1e293b);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: Arial;
            }

            .card-box {
                width: 450px;
                background: #ffffff;
                padding: 35px;
                border-radius: 18px;
                box-shadow: 0 25px 60px rgba(0,0,0,0.35);
            }

            .title {
                text-align: center;
                font-weight: bold;
                margin-bottom: 10px;
            }

            .subtitle {
                text-align: center;
                font-size: 13px;
                color: gray;
                margin-bottom: 20px;
            }

            .hint {
                font-size: 12px;
                color: #6b7280;
                text-align: center;
                margin-bottom: 20px;
            }
    </style>
</head>

<body>

    <div class="card-box">

        <h3 class="title">Sistem Bağlantı Ayarları</h3>

        <p class="subtitle">
            ERP sisteminin veritabanına bağlanabilmesi için gerekli bilgileri girin
        </p>

        <div class="hint">
            ⚠️ Bu bilgiler sistem çalışması için zorunludur
        </div>

        <!-- 🔥 MESAJ ALANI (BURASI EKLENDİ) -->
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        <form asp-action="Settings" method="post">

            <div class="mb-2">
                <input class="form-control" name="Server" placeholder="SQL Server (örn: localhost)" />
            </div>

            <div class="mb-2">
                <input class="form-control" name="Database" placeholder="Veritabanı adı" />
            </div>

            <div class="mb-2">
                <input class="form-control" name="Username" placeholder="Kullanıcı adı" />
            </div>

            <div class="mb-3">
                <input class="form-control" type="password" name="Password" placeholder="Şifre" />
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Bağlantıyı Test Et ve Devam Et
            </button>

        </form>

    </div>

</body>
</html>