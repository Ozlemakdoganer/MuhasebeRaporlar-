@{
    Layout = null;
}

<div style="max-width:500px;">
    <h4 class="mb-3">Firma & Dönem Seçimi</h4>

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="SelectCompany">

                <div class="mb-3">
                    <label class="form-label">Firma</label>
                    <select id="firmaSelect" name="firmNr" class="form-select" onchange="firmaDegisti()">
                        <option value="">Seçiniz</option>

                        @foreach (var f in ViewBag.Firmalar)
                        {
                            if (ViewBag.SelectedFirm != null && ViewBag.SelectedFirm == f.Nr)
                            {
                                <option value="@f.Nr" selected>@f.Nr - @f.Name</option>
                            }
                            else
                            {
                                <option value="@f.Nr">@f.Nr - @f.Name</option>
                            }
                        }

                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Dönem</label>
                    <select id="donemSelect" name="periodNr" class="form-select">
                        <option value="">Önce firma seçiniz</option>
                    </select>
                </div>
                <input type="hidden" id="selectedFirmValue" value="@ViewBag.SelectedFirm" />
                <input type="hidden" id="selectedPeriodValue" value="@ViewBag.SelectedPeriod" />


                <button type="submit" class="btn btn-primary w-100">Devam Et</button>
            </form>
        </div>
    </div>
</div>

