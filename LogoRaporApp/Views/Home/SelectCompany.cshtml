@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Firma Seçimi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#0f172a; display:flex; align-items:center; justify-content:center; height:100vh;">

    <div style="width:400px; background:white; padding:25px; border-radius:10px;">

        <h4 class="text-center">Firma & Dönem Seç</h4>

        <form method="post" asp-action="SelectCompany">

            <!-- FIRMA -->
            <div class="mb-3">
                <label>Firma</label>
                <select id="firmaSelect" name="firmNr" class="form-control" onchange="firmaDegisti()">
                    <option value="">Seçiniz</option>

                    @foreach (var f in ViewBag.Firmalar)
                    {
                        <option value="@f.Nr">@f.Nr - @f.Name</option>
                    }
                </select>
            </div>

            <!-- DONEM -->
            <div class="mb-3">
                <label>Dönem</label>
                <select id="donemSelect" name="periodNr" class="form-control">
                    <option value="">Önce firma seçiniz</option>
                </select>
            </div>

            <button class="btn btn-primary w-100">Devam Et</button>

        </form>

    </div>

    <script>
                        function firmaDegisti() {

                var select = document.getElementById("firmaSelect");
                var firma = select.value;

                fetch('/Home/GetPeriods?firmNr=' + firma)
                    .then(res => res.json())
                    .then(data => {

                        var select2 = document.getElementById("donemSelect");
                        select2.innerHTML = "";

                        data.forEach(function (item) {
                            var opt = document.createElement("option");
                            opt.value = item.periodNr;
                            opt.text = item.periodNr;
                            select2.appendChild(opt);
                        });

                    });
            }
    </script>

</body>
</html>