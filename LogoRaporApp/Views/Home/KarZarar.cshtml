@model List<LogoRaporApp.Models.GelirTablosuSonucItem>
@{
    Layout = null;
}

<style>
    .gt-satir {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 7px 16px;
        border-bottom: 1px solid #e5e7eb;
        font-size: 13px;
        color: #222;
    }

    .gt-satir.anabaslik {
        background: #f0f9f4;
        font-weight: 700;
        color: #1F7A5A;
        border-left: 4px solid #1F7A5A;
        margin-top: 6px;
        font-size: 13px;
    }

    .gt-satir.altbaslik {
        padding-left: 32px;
        color: #222;
        background: #ffffff;
    }

    .gt-satir.toplam {
        background: #1F7A5A;
        font-weight: 700;
        font-size: 14px;
        margin-top: 4px;
        margin-bottom: 4px;
        color: white;
    }

    .gt-satir.toplam.zarar {
        background: #dc3545;
        color: white;
    }

    .gt-tutar {
        min-width: 150px;
        text-align: right;
        font-weight: 600;
        color: #222;
    }

    .gt-satir.toplam .gt-tutar {
        color: white;
    }

    .tutar-pozitif { color: #1F7A5A !important; }
    .tutar-negatif { color: #dc3545 !important; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 print-hide">
    <h4 class="mb-0">Gelir Tablosu</h4>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="gelirTablosuAnaliziGetir()">← Geri</button>
        <button type="button" class="btn btn-outline-dark btn-sm" onclick="window.print()">Yazdır</button>
    </div>
</div>

<div class="mb-3 p-3 print-hide" style="background:#f8fbf9; border:1px solid #dcebe2; border-radius:10px;">
    <div><strong>Firma:</strong> @ViewBag.Firma</div>
    <div><strong>Tarih Aralığı:</strong> @ViewBag.BaslangicTarihi - @ViewBag.BitisTarihi</div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-0">
                @foreach (var item in Model)
                {
                    string tip = item.KarlilikOrani ?? "";
                    string satirClass = tip;
                    string tutarClass = "";

                    if (tip == "toplam")
                    {
                        satirClass = item.Tutar >= 0 ? "toplam" : "toplam zarar";
                    }
                    else if (tip == "altbaslik" && item.Tutar != 0)
                    {
                        tutarClass = item.Tutar >= 0 ? "tutar-pozitif" : "tutar-negatif";
                    }

                    <div class="gt-satir @satirClass">
                        <div>@item.Aciklama</div>
                        <div class="gt-tutar @tutarClass">
                            @(item.Tutar == 0 && tip == "anabaslik" ? "" : item.Tutar.ToString("N2"))
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="mb-3">Özet Grafik</h5>
                <canvas id="gelirTablosuGrafik"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="[cdn.jsdelivr.net](https://cdn.jsdelivr.net/npm/chart.js)"></script>
<script>
    var labels = [
        "Net Satışlar",
        "Brüt Kar",
        "Faaliyet Karı",
        "Olağan Kar",
        "Dönem Karı",
        "Dönem Net Karı"
    ];

    var values = [
    parseFloat("@ViewBag.NetSatislar"),
    parseFloat("@ViewBag.BrutKar"),
    parseFloat("@ViewBag.FaaliyetKar"),
    parseFloat("@ViewBag.OlaganKar"),
    parseFloat("@ViewBag.DonemKar"),
    parseFloat("@ViewBag.DonemNetKar")
];


    var colors = values.map(function(v) {
        return v >= 0 ? 'rgba(31, 122, 90, 0.7)' : 'rgba(220, 53, 69, 0.7)';
    });

    var borderColors = values.map(function(v) {
        return v >= 0 ? '#1F7A5A' : '#dc3545';
    });

    var ctx = document.getElementById('gelirTablosuGrafik').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Tutar (₺)',
                data: values,
                backgroundColor: colors,
                borderColor: borderColors,
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    ticks: {
                        callback: function(value) {
                            return value.toLocaleString('tr-TR') + ' ₺';
                        }
                    }
                },
                x: {
                    ticks: { font: { size: 11 } }
                }
            }
        }
    });
</script>
