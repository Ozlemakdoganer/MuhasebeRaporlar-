@model List<LogoRaporApp.Models.CariListeItem>

@{
    Layout = null;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Cari Ekstre</h4>

    <div class="d-flex gap-2">
        <button type="button" class="btn btn-primary">Ara</button>
        <button type="button" class="btn btn-outline-secondary">Temizle</button>
        <button type="button" class="btn btn-outline-success">Excel</button>
        <button type="button" class="btn btn-outline-dark">Yazdır</button>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 mb-2">
                <label class="form-label">Cari Kod / Ünvan</label>
                <input type="text" class="form-control" placeholder="Arama yapınız" />
            </div>

            <div class="col-md-3 mb-2">
                <label class="form-label">Başlangıç Tarihi</label>
                <input type="date" class="form-control" />
            </div>

            <div class="col-md-3 mb-2">
                <label class="form-label">Bitiş Tarihi</label>
                <input type="date" class="form-control" />
            </div>

            <div class="col-md-2 mb-2 d-flex align-items-end">
                <button type="button"
                        class="btn btn-outline-primary w-100"
                        onclick="var alan = document.getElementById('detayliFiltreAlani'); alan.style.display = (alan.style.display === 'none' ? 'block' : 'none');">
                    Detaylı Filtreler ▾
                </button>
            </div>
        </div>

        <div id="detayliFiltreAlani" style="display:none; margin-top:15px;">
            <hr />

            <div class="row">
                <div class="col-md-2 mb-2">
                    <label class="form-label">Cari Kod Başlangıcı</label>
                    <input type="text" class="form-control" placeholder="Örn: 120.01" />
                </div>

                <div class="col-md-2 mb-2">
                    <label class="form-label">Özel Kod</label>
                    <select class="form-select">
                        <option>Seçiniz</option>
                    </select>
                </div>

                <div class="col-md-2 mb-2">
                    <label class="form-label">Listeleme</label>
                    <select class="form-select">
                        <option>Koda Göre</option>
                        <option>Açıklamaya Göre</option>
                    </select>
                </div>

                <div class="col-md-2 mb-2">
                    <label class="form-label">Fatura Detayı</label>
                    <select class="form-select">
                        <option>Hayır</option>
                        <option>Evet</option>
                    </select>
                </div>

                <div class="col-md-2 mb-2">
                    <label class="form-label">Bordro Detayı</label>
                    <select class="form-select">
                        <option>Hayır</option>
                        <option>Evet</option>
                    </select>
                </div>

                <div class="col-md-2 mb-2">
                    <label class="form-label">Sipariş Detayı</label>
                    <select class="form-select">
                        <option>Hayır</option>
                        <option>Evet</option>
                    </select>
                </div>
                <div class="col-md-2 mb-2">
                    <label class="form-label">Hareket Görmeyenler</label>
                    <select class="form-select">
                        <option>Listelensin</option>
                        <option>Listelenmesin</option>
                    </select>
                </div>

            </div>
        </div>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div>Veri bulunamadı</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Cari Kod</th>
                <th>Ünvan</th>
                <th class="text-end">Bakiye</th>
                <th>VKN / TCKN</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.CariKod</td>
                    <td>@c.Unvan</td>
                    <td class="text-end">@c.Bakiye</td>
                    <td>@c.VknTckn</td>
                </tr>
            }
        </tbody>
    </table>

}

<script>
    function toggleDetayliFiltre() {
        var alan = document.getElementById("detayliFiltreAlani");

        if (alan.style.display === "none") {
            alan.style.display = "block";
        } else {
            alan.style.display = "none";
        }
    }
</script>
