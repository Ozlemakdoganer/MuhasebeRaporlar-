@model LogoRaporApp.Models.DbSetting

@{
    Layout = null;
}

<div>
    <h4 class="mb-3">Veritabanı Ayarları</h4>

    <p class="text-muted mb-4">
        ERP veritabanı bağlantı bilgilerini buradan tanımlayabilirsiniz.
    </p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <form id="dbSettingsForm" asp-action="SaveDbSettings" method="post">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">SQL Server</label>
                <input class="form-control" name="Server" placeholder="Örn: localhost" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Veritabanı</label>
                <input class="form-control" name="Database" placeholder="Veritabanı adı" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input class="form-control" name="Username" placeholder="Kullanıcı adı" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Şifre</label>
                <input class="form-control" type="password" name="Password" placeholder="Şifre" />
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Bağlantıyı Kaydet</button>
            <button type="button" class="btn btn-outline-secondary" onclick="ayarlarGetir()">Geri</button>
        </div>
    </form>
</div>
