@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background: linear-gradient(135deg, #3AAE6E, #1F7A5A, #49C784);
                height: 100vh;
                margin: 0;
                display: flex;
                justify-content: center; /* yatay ortalama */
                align-items: center; /* dikey ortalama */
            }

            .login-box {
                width: 400px;
                padding: 36px;
                background: rgba(255, 255, 255, 0.96);
                border-radius: 20px;
                box-shadow: 0 22px 50px rgba(31, 122, 90, 0.18);
                backdrop-filter: blur(6px);
            }



            .login-header {
                text-align: center;
                margin-bottom: 24px;
            }

            .title {
                margin-bottom: 6px;
                font-weight: bold;
                color: #0F3D2E;
            }

            .subtitle {
                margin: 0;
                font-size: 14px;
                color: #5f6f65;
            }


            .btn-primary {
                background-color: #1F7A5A;
                border-color: #1F7A5A;
            }

                .btn-primary:hover,
                .btn-primary:focus,
                .btn-primary:active {
                    background-color: #176347 !important;
                    border-color: #176347 !important;
                }

            .form-control {
                height: 46px;
                border-radius: 10px;
                border: 1px solid #d7e8dd;
            }

                .form-control:focus {
                    border-color: #1F7A5A;
                    box-shadow: 0 0 0 0.2rem rgba(31, 122, 90, 0.25);
                }


            .login-icon {
                font-size: 34px;
                margin-bottom: 10px;
                filter: drop-shadow(0 4px 10px rgba(31, 122, 90, 0.18));
            }

            .login-footer {
                margin-top: 24px;
                text-align: center;
                font-size: 12px;
                color: #6b7d72;
                line-height: 1.6;
            }

            .password-wrapper {
                position: relative;
            }

            .toggle-password {
                position: absolute;
                top: 50%;
                right: 12px;
                transform: translateY(-50%);
                border: none;
                background: transparent;
                font-size: 16px;
                cursor: pointer;
                padding: 0;
                line-height: 1;
            }

                .toggle-password:hover {
                    opacity: 0.8;
                }

    </style>
</head>

<body>

    <div class="login-box">

        <div class="login-header">
            <div class="login-icon">🔐</div>
            <h3 class="title">Logo ERP Raporlama</h3>
            <p class="subtitle">Güvenli giriş ekranı</p>
        </div>



        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Hata
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post" autocomplete="on">


            <div class="mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input type="text"
                       name="username"
                       class="form-control"
                       placeholder="Kullanıcı adı"
                       required
                       autocomplete="username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Şifre</label>
                <div class="password-wrapper">
                    <input type="password"
                           id="passwordInput"
                           name="password"
                           class="form-control"
                           placeholder="Şifre"
                           required
                           autocomplete="current-password" />
                    <button type="button" class="toggle-password" onclick="togglePassword()" id="togglePasswordBtn">👁</button>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Giriş Yap
            </button>

        </form>
        <div class="login-footer">
            <div>Artuklu Muhasebe Ve Yazılım Çözümleri</div>
            <div>ERP Reporting Suite • v1.0</div>
        </div>
    </div>

    <script>
                   
            function togglePassword() {
                var passwordInput = document.getElementById("passwordInput");
                var button = document.getElementById("togglePasswordBtn");

                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    button.innerText = "🙈";
                } else {
                    passwordInput.type = "password";
                    button.innerText = "👁";
                }
            }    

    </script>

</body>
</html>