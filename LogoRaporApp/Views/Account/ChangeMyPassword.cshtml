@{
    Layout = null;
}

<div style="max-width:400px;">
    <div class="d-flex align-items-center gap-2 mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="ayarlarGetir()">← Geri</button>
        <h4 class="mb-0">Şifremi Değiştir</h4>
    </div>

    @if (ViewBag.Hata != null)
    {
        <div class="alert alert-danger">@ViewBag.Hata</div>
    }

    @if (ViewBag.Basari != null)
    {
        <div class="alert alert-success">@ViewBag.Basari</div>
    }

    <div class="card">
        <div class="card-body">
            <form id="sifreDegistirForm">
                <div class="mb-3">
                    <label class="form-label">Mevcut Şifre</label>
                    <input type="password" id="mevcutSifre" class="form-control" placeholder="Mevcut şifre" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Yeni Şifre</label>
                    <input type="password" id="yeniSifre" class="form-control" placeholder="Yeni şifre" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Yeni Şifre Tekrar</label>
                    <input type="password" id="yeniSifreTekrar" class="form-control" placeholder="Yeni şifre tekrar" />
                </div>
                <div id="sifreHata" class="text-danger mb-2" style="display:none;"></div>
                <div id="sifreBasari" class="text-success mb-2" style="display:none;"></div>
                <button type="button" class="btn btn-primary w-100" onclick="sifreDegistir()">Değiştir</button>
            </form>
        </div>
    </div>
</div>

<script>
    function sifreDegistir() {
        var mevcut = document.getElementById("mevcutSifre").value;
        var yeni = document.getElementById("yeniSifre").value;
        var tekrar = document.getElementById("yeniSifreTekrar").value;

        document.getElementById("sifreHata").style.display = "none";
        document.getElementById("sifreBasari").style.display = "none";

        if (!mevcut || !yeni || !tekrar) {
            document.getElementById("sifreHata").style.display = "block";
            document.getElementById("sifreHata").innerText = "Tüm alanları doldurun.";
            return;
        }

        if (yeni !== tekrar) {
            document.getElementById("sifreHata").style.display = "block";
            document.getElementById("sifreHata").innerText = "Yeni şifreler eşleşmiyor.";
            return;
        }

        var formData = new FormData();
        formData.append("currentPassword", mevcut);
        formData.append("newPassword", yeni);

        fetch('/Account/ChangeMyPassword', { method: 'POST', body: formData })
            .then(res => res.text())
            .then(data => {
                if (data === "SUCCESS") {
                    document.getElementById("sifreBasari").style.display = "block";
                    document.getElementById("sifreBasari").innerText = "Şifreniz başarıyla değiştirildi.";
                    document.getElementById("sifreDegistirForm").reset();
                } else {
                    document.getElementById("sifreHata").style.display = "block";
                    document.getElementById("sifreHata").innerText = data;
                }
            });
    }
</script>